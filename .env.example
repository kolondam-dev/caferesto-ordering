# Database (SQLite untuk dev — ganti ke PostgreSQL/MySQL di production)
DATABASE_URL="file:./dev.db"

# JWT secret untuk auth custom
JWT_SECRET="change-me-to-a-long-random-string"

# Payment gateway: "mock" (default) atau "midtrans"
PAYMENT_PROVIDER="mock"
# Midtrans-ready: tinggal isi key lalu set PAYMENT_PROVIDER="midtrans"
MIDTRANS_SERVER_KEY=""
MIDTRANS_CLIENT_KEY=""
MIDTRANS_IS_PRODUCTION="false"

# AI Agent — Gemini Flash (Google AI Studio universal key)
# Kosongkan untuk mode mock (jawaban dihasilkan dari data asli tanpa LLM)
GEMINI_API_KEY=""
GEMINI_MODEL="gemini-2.0-flash"
