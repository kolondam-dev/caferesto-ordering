# Database — PostgreSQL (Neon untuk cloud, atau docker compose untuk lokal offline)
# Neon: pakai POOLED connection string (host mengandung "-pooler")
# Dev lokal disarankan menunjuk ke Neon branch `dev` agar terpisah dari production.
DATABASE_URL="postgresql://user:password@xxx-pooler.region.aws.neon.tech/neondb?sslmode=require"

# JWT secret untuk auth custom — WAJIB diganti string acak panjang di production
JWT_SECRET="change-me-to-a-long-random-string"

# Payment gateway: "mock" (default) atau "midtrans"
PAYMENT_PROVIDER="mock"
# Midtrans-ready: tinggal isi key lalu set PAYMENT_PROVIDER="midtrans"
MIDTRANS_SERVER_KEY=""
MIDTRANS_CLIENT_KEY=""
MIDTRANS_IS_PRODUCTION="false"

# AI Agent — Gemini Flash (Google AI Studio universal key)
# Kosongkan untuk mode mock (jawaban dihasilkan dari data asli tanpa LLM)
GEMINI_API_KEY=""
GEMINI_MODEL="gemini-2.0-flash"

# Object storage — Cloudflare R2 (S3-compatible). Kosongkan semua = simpan ke
# disk lokal (hanya untuk dev; tidak berfungsi di serverless/Vercel).
R2_ACCOUNT_ID=""
R2_ACCESS_KEY_ID=""
R2_SECRET_ACCESS_KEY=""
R2_BUCKET=""
# URL publik bucket (r2.dev atau custom domain), tanpa trailing slash
R2_PUBLIC_URL=""

# Cloudflare Turnstile (anti-bot di form scan QR, login, register).
# Kosongkan keduanya = fitur nonaktif (dev/CI).
NEXT_PUBLIC_TURNSTILE_SITE_KEY=""
TURNSTILE_SECRET_KEY=""
