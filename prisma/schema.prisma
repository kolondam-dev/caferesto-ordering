// CafeResto — full schema (core + PRO modules)
// SQLite tidak mendukung enum Prisma; nilai status memakai String,
// konstanta terdefinisi di src/lib/constants.ts

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql" // production: Neon; dev lokal: Neon branch `dev` (lihat docs/DEPLOYMENT.md)
  url      = env("DATABASE_URL")
}

// ───────────────────────── Core ─────────────────────────

// Staff (OWNER/MANAGER/CASHIER/KITCHEN) login dengan email+password.
// Customer login dengan no HP + verifikasi WA OTP (tanpa password).
model User {
  id           String       @id @default(cuid())
  name         String
  email        String?      @unique
  phone        String?      @unique
  passwordHash String? // null untuk customer (auth via WA OTP)
  role         String       @default("CUSTOMER") // OWNER|MANAGER|CASHIER|KITCHEN|CUSTOMER
  baseSalary   Int          @default(0)
  createdAt    DateTime     @default(now())
  bookings     Booking[]
  orders       Order[]
  attendances  Attendance[]
  payslips     Payslip[]
  chats        ChatMessage[]
  approvalsRequested ApprovalRequest[] @relation("ApprovalRequester")
  approvalsDecided   ApprovalRequest[] @relation("ApprovalDecider")
  participations     OrderParticipant[]
}

// OTP verifikasi WhatsApp untuk login/registrasi customer (mock-ready).
// Satu kode aktif per nomor (upsert by phone).
model WaOtp {
  phone     String   @id
  code      String
  name      String
  expiresAt DateTime
  attempts  Int      @default(0)
  createdAt DateTime @default(now())
}

model Setting {
  key   String @id
  value String
}

// Dedup aksi tulis kritis saat client retry (koneksi putus, respons hilang).
// Client mengirim header X-Idempotency-Key; respons pertama disimpan & direplay.
model IdempotencyKey {
  key       String   @id
  status    Int
  body      String
  createdAt DateTime @default(now())
}

model Table {
  id       String    @id @default(cuid())
  number   Int       @unique
  name     String
  capacity Int
  status   String    @default("OPEN") // OPEN|BOOKED|OCCUPIED
  code     String?   @unique // slug acak untuk URL QR meja (/t/[code])
  bookings Booking[]
  orders   Order[]
}

model MenuCategory {
  id    String     @id @default(cuid())
  name  String
  sort  Int        @default(0)
  items MenuItem[]
}

model MenuItem {
  id          String       @id @default(cuid())
  name        String
  description String?
  price       Int
  costPrice   Int          @default(0) // HPP untuk perhitungan margin (backoffice costing)
  imageUrl    String?
  prepMinutes Int? // estimasi lama pembuatan (tampil di kartu menu)
  available   Boolean      @default(true)
  categoryId  String
  category    MenuCategory @relation(fields: [categoryId], references: [id])
  orderItems  OrderItem[]
  photos      MenuPhoto[]
}

// Katalog multi-foto per menu: satu foto utama (kartu/list), sisanya thumbnail.
// Fondasi untuk tema dinamis "buku menu" (konfigurasi tema = modul PRO Menu).
model MenuPhoto {
  id         String   @id @default(cuid())
  menuItemId String
  menuItem   MenuItem @relation(fields: [menuItemId], references: [id])
  url        String
  isPrimary  Boolean  @default(false)
  sort       Int      @default(0)
  createdAt  DateTime @default(now())
}

// Lifecycle booking:
// PENDING ──(bayar fee sebelum payDeadlineAt = H-x)──▶ CONFIRMED (table BOOKED)
//   └─ lewat deadline ──▶ EXPIRED (table OPEN)
// CONFIRMED ──(buka order ≤ grace menit setelah scheduledAt)──▶ SEATED (table OCCUPIED)
//   └─ lewat grace ──▶ CANCELED (table OPEN)
// SEATED ──(order dibayar)──▶ COMPLETED (table OPEN)
model Booking {
  id             String    @id @default(cuid())
  code           String    @unique
  customerId     String
  customer       User      @relation(fields: [customerId], references: [id])
  tableId        String
  table          Table     @relation(fields: [tableId], references: [id])
  partySize      Int
  scheduledAt    DateTime
  payDeadlineAt  DateTime
  status         String    @default("PENDING")
  feeAmount      Int
  feePaidAt      DateTime?
  canceledReason String?
  createdAt      DateTime  @default(now())
  order          Order?
  payments       Payment[]
}

model Order {
  id             String      @id @default(cuid())
  code           String      @unique
  type           String      @default("DINE_IN") // DINE_IN|TAKEAWAY
  // Jalur POS/booking: OPEN|PAID|CANCELED (pay-later)
  // Jalur QR (Scan & Serve, pay-first): DRAFT|AWAITING_PAYMENT|AWAITING_VALIDATION|IN_KITCHEN|PAID|EXPIRED
  status         String      @default("OPEN")
  source         String      @default("POS") // QR|POS|BOOKING
  splitMode      String? // SINGLE|UPFRONT (dipilih host saat konfirmasi, jalur QR)
  lastActivityAt DateTime    @default(now()) // untuk TTL draft
  tableId        String?
  table          Table?      @relation(fields: [tableId], references: [id])
  bookingId      String?     @unique
  booking        Booking?    @relation(fields: [bookingId], references: [id])
  customerId     String?
  customer       User?       @relation(fields: [customerId], references: [id])
  customerName   String?
  customerPhone  String?
  channel        String? // takeaway: WALKIN|SHOPEEFOOD|GOFOOD|WA
  depositApplied Int         @default(0) // booking fee yang dikreditkan ke tagihan
  taxPercent     Int         @default(10)
  // Snapshot service fee saat order dibuat (agar tagihan deterministik)
  serviceFeeType  String? // PERCENT|FLAT, null = tanpa service fee
  serviceFeeValue Int     @default(0)
  createdAt      DateTime    @default(now())
  closedAt       DateTime?
  items          OrderItem[]
  payments       Payment[]
  participants   OrderParticipant[]
}

// Peserta order kolaboratif jalur QR (guest, tanpa login).
// Host = pemindai pertama; member hanya mengelola item miliknya.
model OrderParticipant {
  id       String      @id @default(cuid())
  orderId  String
  order    Order       @relation(fields: [orderId], references: [id])
  name     String
  phone    String? // opsional — "struk digital dikirim ke sini jika berminat"
  isHost   Boolean     @default(false)
  // Tautan ke akun customer (terisi bila peserta sudah login / verifikasi WA).
  // Inilah jembatan agar order jalur QR muncul di riwayat customer.
  userId   String?
  user     User?       @relation(fields: [userId], references: [id])
  // Guest id dari cookie. Device yang sama boleh muncul di banyak order
  // (ronde baru / meja lain) — unik hanya di dalam satu order.
  token    String
  joinedAt DateTime    @default(now())
  items    OrderItem[]

  @@unique([orderId, token])
}

model OrderItem {
  id            String            @id @default(cuid())
  orderId       String
  order         Order             @relation(fields: [orderId], references: [id])
  menuItemId    String
  menuItem      MenuItem          @relation(fields: [menuItemId], references: [id])
  participantId String? // atribusi item ke peserta (jalur QR)
  participant   OrderParticipant? @relation(fields: [participantId], references: [id])
  nameSnapshot  String
  price         Int
  qty           Int
  notes         String?
  status        String            @default("QUEUED") // DRAFT|QUEUED|PREPARING|READY|SERVED|CANCELED
  createdAt     DateTime          @default(now())
}

// Abstraksi pembayaran — provider: mock|midtrans|cash
model Payment {
  id        String    @id @default(cuid())
  ref       String    @unique
  provider  String
  method    String    @default("qris")
  purpose   String // ORDER|BOOKING_FEE|SPLIT
  status    String    @default("PENDING") // PENDING|SETTLED|FAILED|EXPIRED
  amount    Int
  payerName String?
  orderId   String?
  order     Order?    @relation(fields: [orderId], references: [id])
  participantId String? // pembayar share UPFRONT (jalur QR)
  bookingId String?
  booking   Booking?  @relation(fields: [bookingId], references: [id])
  meta      String?
  createdAt DateTime  @default(now())
  settledAt DateTime?
}

model ChatMessage {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id])
  role      String // user|assistant
  content   String
  createdAt DateTime @default(now())
}

// Antrian persetujuan owner untuk aksi sensitif (batal/hapus order, edit menu).
// Aksi dari non-owner dicatat sebagai PENDING; owner menyetujui → dieksekusi.
// `payload` menyimpan detail perubahan (JSON) agar bisa dijalankan saat approve.
model ApprovalRequest {
  id            String    @id @default(cuid())
  type          String // ORDER_CANCEL|ORDER_DELETE|MENU_UPDATE|MENU_DELETE
  status        String    @default("PENDING") // PENDING|APPROVED|REJECTED
  requestedById String
  requestedBy   User      @relation("ApprovalRequester", fields: [requestedById], references: [id])
  requestedName String // snapshot nama peminta (tetap terbaca walau user berubah)
  targetType    String // ORDER|MENU
  targetId      String
  targetLabel   String? // ringkasan target (kode order / nama menu) untuk ditampilkan
  reason        String? // alasan peminta
  payload       String    @default("{}") // detail perubahan (JSON)
  decidedById   String?
  decidedBy     User?     @relation("ApprovalDecider", fields: [decidedById], references: [id])
  decisionNote  String?
  decidedAt     DateTime?
  createdAt     DateTime  @default(now())

  @@index([status, createdAt])
}

// ───────────────────────── PRO ─────────────────────────

model Supplier {
  id       String          @id @default(cuid())
  name     String
  contact  String?
  phone    String?
  email    String?
  address  String?
  items    InventoryItem[]
  payables Payable[]
}

model InventoryItem {
  id         String          @id @default(cuid())
  sku        String          @unique
  name       String
  unit       String          @default("pcs")
  stock      Float           @default(0)
  minStock   Float           @default(0)
  costPrice  Int             @default(0)
  supplierId String?
  supplier   Supplier?       @relation(fields: [supplierId], references: [id])
  movements  StockMovement[]
}

model StockMovement {
  id        String        @id @default(cuid())
  itemId    String
  item      InventoryItem @relation(fields: [itemId], references: [id])
  type      String // IN|OUT|ADJUST
  qty       Float
  note      String?
  refType   String?
  refId     String?
  createdAt DateTime      @default(now())
}

model Payable {
  id         String   @id @default(cuid())
  supplierId String
  supplier   Supplier @relation(fields: [supplierId], references: [id])
  invoiceNo  String
  amount     Int
  paidAmount Int      @default(0)
  dueDate    DateTime
  status     String   @default("UNPAID") // UNPAID|PARTIAL|PAID
  notes      String?
  createdAt  DateTime @default(now())
}

model Account {
  id    String        @id @default(cuid())
  code  String        @unique
  name  String
  type  String // ASSET|LIABILITY|EQUITY|REVENUE|EXPENSE
  lines JournalLine[]
}

model JournalEntry {
  id        String        @id @default(cuid())
  date      DateTime      @default(now())
  memo      String
  refType   String?
  refId     String?
  createdAt DateTime      @default(now())
  lines     JournalLine[]
}

model JournalLine {
  id        String       @id @default(cuid())
  entryId   String
  entry     JournalEntry @relation(fields: [entryId], references: [id])
  accountId String
  account   Account      @relation(fields: [accountId], references: [id])
  debit     Int          @default(0)
  credit    Int          @default(0)
}

model Attendance {
  id       String    @id @default(cuid())
  userId   String
  user     User      @relation(fields: [userId], references: [id])
  clockIn  DateTime  @default(now())
  clockOut DateTime?
  note     String?
}

model PayrollPeriod {
  id        String    @id @default(cuid())
  name      String
  startDate DateTime
  endDate   DateTime
  status    String    @default("DRAFT") // DRAFT|FINALIZED|PAID
  payslips  Payslip[]
}

model Payslip {
  id         String        @id @default(cuid())
  periodId   String
  period     PayrollPeriod @relation(fields: [periodId], references: [id])
  userId     String
  user       User          @relation(fields: [userId], references: [id])
  baseSalary Int
  allowance  Int           @default(0)
  deduction  Int           @default(0)
  netPay     Int
  status     String        @default("DRAFT") // DRAFT|PAID
  paidAt     DateTime?
}
